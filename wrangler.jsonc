{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pipemailer",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist"
  },
  "build": {
    "command": "npm run build"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
